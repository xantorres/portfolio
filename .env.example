# Canonical site URL — used for metadata, sitemap, OG card. Falls back to xantorres.dev.
NEXT_PUBLIC_SITE_URL=https://xtorres.vercel.app

# --- Email delivery (Resend) ---
# When RESEND_API_KEY is set, the contact form sends real email.
# When it is absent, submissions are logged server-side and the form still returns success.
RESEND_API_KEY=
# Recipient for contact-form messages. REQUIRED when RESEND_API_KEY is set.
CONTACT_TO_EMAIL=
# Verified sender on your Resend account. Defaults to onboarding@resend.dev for testing.
RESEND_FROM_EMAIL=

# --- Anti-spam ---
# Cloudflare Turnstile — free, low-friction captcha.
# Create a site at https://dash.cloudflare.com/?to=/:account/turnstile and paste both keys.
# When either key is missing, the captcha is silently disabled but the honeypot
# and 2s-minimum-fill-time protections still apply.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis — per-IP rate limiting (5 requests / 10 min).
# Create a free Redis DB at https://console.upstash.com and copy the REST creds.
# When either var is missing, rate limiting is silently disabled.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
